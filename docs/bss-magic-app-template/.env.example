# BSS Magic App Template - Environment Variables
# Copy this file to .env and fill in the values

# ===========================================
# Core API Configuration
# ===========================================

# BSS Magic API URL
VITE_BSS_MAGIC_API_URL=https://adapters.bss-magic.totogi.solutions

# Ontology API URL (defaults to BSS_MAGIC_API_URL if not set)
VITE_ONTOLOGY_API_URL=https://adapters.bss-magic.totogi.solutions

# AI FDE API URL (for AI block service)
VITE_AI_FDE_API_URL=https://adapter.bss-magic.totogi.solutions

# ===========================================
# AWS Cognito Configuration
# ===========================================

# Cognito region
VITE_COGNITO_REGION=ap-southeast-1

# AWS region
VITE_AWS_REGION=ap-southeast-1

# Cognito User Pool ID
VITE_COGNITO_USER_POOL_ID=ap-southeast-1_1wdDA5QQl

# Cognito App Client ID
VITE_COGNITO_CLIENT_ID=6pr9gtevg8rhp16krol2u0k8ku

# ===========================================
# Authentication Behavior
# ===========================================

# Show login form when not authenticated
# - true: Show login form (standalone mode)
# - false: Wait for auth tokens via postMessage (iframe mode)
VITE_SHOW_LOGIN=true

# ===========================================
# Optional: Google Maps
# ===========================================

# Google Maps API Key (if using maps features)
VITE_GOOGLE_MAPS_API_KEY=
