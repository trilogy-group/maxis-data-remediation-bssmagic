## 📊 SOQL Queries for Dashboard Metrics

### 1. Total Contract Value & MRR

```sql
-- Total Contract Value
SELECT 
  SUM(Total_Contract_Value__c) AS TotalTCV,
  SUM(cscfga__Total_One_Off_Charge__c) AS TotalOneOff,
  SUM(cscfga__Total_Recurring_Charge__c) AS MonthlyMRR,
  COUNT(Id) AS ActiveSolutions
FROM csord__Solution__c
WHERE (csordtelcoa__Solution_Status__c = 'Active' 
   OR csordtelcoa__Solution_Status__c = 'Completed')
  AND Total_Contract_Value__c != null
```

### 2. Revenue at Risk (Stuck Pipeline)

```sql
-- Stuck Baskets
SELECT 
  'Stuck Baskets' AS Category,
  COUNT(Id) AS Count,
  SUM(cscfga__Total_One_Off_Charge__c + (cscfga__Total_Recurring_Charge__c * 12)) AS Value,
  AVG(DAYS_BETWEEN(CreatedDate, TODAY())) AS AvgDaysStuck
FROM cscfga__Product_Basket__c
WHERE cscfga__Basket_Status__c = 'Order Generation'
  AND CreatedDate >= LAST_N_DAYS:90

UNION ALL

-- Failed Migrations
SELECT 
  'Failed Migrations' AS Category,
  COUNT(Id) AS Count,
  SUM(Total_Contract_Value__c) AS Value,
  NULL AS AvgDaysStuck
FROM csord__Solution__c
WHERE csord__External_Identifier__c = 'Not Migrated Successfully'
  AND CreatedBy.Name = 'Migration User'

UNION ALL

-- Delayed Orders
SELECT 
  'Delayed Orders' AS Category,
  COUNT(Id) AS Count,
  SUM(TotalAmount) AS Value,
  AVG(DAYS_BETWEEN(CreatedDate, TODAY())) AS AvgDaysStuck
FROM csord__Order__c
WHERE csordtelcoa__Order_Status__c = 'In Progress'
  AND CreatedDate < LAST_N_DAYS:7
```

### 3. Order Cycle Time Analysis

```sql
SELECT 
  AVG(DAYS_BETWEEN(CreatedDate, csordtelcoa__Order_Completion_Date__c)) AS AvgCycleTime,
  MIN(DAYS_BETWEEN(CreatedDate, csordtelcoa__Order_Completion_Date__c)) AS BestCycleTime,
  MAX(DAYS_BETWEEN(CreatedDate, csordtelcoa__Order_Completion_Date__c)) AS WorstCycleTime,
  PERCENTILE_CONT(0.5) WITHIN GROUP (ORDER BY DAYS_BETWEEN(CreatedDate, csordtelcoa__Order_Completion_Date__c)) AS MedianCycleTime,
  COUNT(Id) AS CompletedOrders
FROM csord__Order__c
WHERE csordtelcoa__Order_Status__c = 'COMPLETED'
  AND csordtelcoa__Order_Completion_Date__c >= LAST_N_DAYS:90
  AND csordtelcoa__Order_Completion_Date__c != null
```

### 4. Process Compliance & Health

```sql
-- Orchestration Health
SELECT 
  CSPOFA__Process_Status__c AS Status,
  COUNT(Id) AS StepCount,
  SUM(CASE WHEN CSPOFA__Is_In_Jeopardy__c = true THEN 1 ELSE 0 END) AS JeopardyCount,
  AVG(DAYS_BETWEEN(CreatedDate, LastModifiedDate)) AS AvgDuration
FROM CSPOFA__Orchestration_Step__c
WHERE CreatedDate >= LAST_N_DAYS:30
GROUP BY CSPOFA__Process_Status__c
ORDER BY COUNT(Id) DESC
```

### 5. Top Error Patterns (Bottlenecks)

```sql
SELECT 
  CSPOFA__Step_Name__c AS StepName,
  COUNT(Id) AS ErrorCount,
  AVG(DAYS_BETWEEN(CreatedDate, LastModifiedDate)) AS AvgDuration,
  MIN(CreatedDate) AS FirstOccurrence,
  MAX(CreatedDate) AS LastOccurrence
FROM CSPOFA__Orchestration_Step__c
WHERE CSPOFA__Process_Status__c = 'Error'
  AND CreatedDate >= LAST_N_DAYS:30
GROUP BY CSPOFA__Step_Name__c
ORDER BY COUNT(Id) DESC
LIMIT 10
```

### 6. Manual Remediation Effort (Estimated)

```sql
-- Cases Requiring Manual Intervention
SELECT 
  RecordType.Name AS CaseType,
  COUNT(Id) AS CaseCount,
  AVG(DAYS_BETWEEN(CreatedDate, ClosedDate)) AS AvgResolutionDays,
  -- Estimate: 30 min per case average
  (COUNT(Id) * 0.5) AS EstimatedHours
FROM Case
WHERE CreatedDate >= LAST_N_DAYS:30
  AND Status = 'Closed'
  AND (RecordType.Name = 'Orchestrator Error'
    OR RecordType.Name = 'Manual Provisioning'
    OR RecordType.Name = 'Validator')
GROUP BY RecordType.Name
ORDER BY COUNT(Id) DESC
```

### 7. Customer Satisfaction Impact

```sql
-- Orders Delayed > 7 Days
SELECT 
  COUNT(Id) AS DelayedOrders,
  AVG(DAYS_BETWEEN(CreatedDate, TODAY())) AS AvgDelay,
  SUM(TotalAmount) AS DelayedRevenue
FROM csord__Order__c
WHERE csordtelcoa__Order_Status__c IN ('In Progress', 'Order Submitted')
  AND DAYS_BETWEEN(CreatedDate, TODAY()) > 7

-- Cases Escalated
SELECT 
  COUNT(Id) AS EscalatedCases,
  AVG(DAYS_BETWEEN(CreatedDate, ClosedDate)) AS AvgResolutionDays
FROM Case
WHERE Priority = 'High'
  AND CreatedDate >= LAST_N_DAYS:30
```

