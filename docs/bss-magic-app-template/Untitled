## 📊 Appendix: Complete Metric Extraction Queries

### A. Financial Metrics

```sql
-- 1. Total Active Contract Value
SELECT SUM(Total_Contract_Value__c) FROM csord__Solution__c 
WHERE csordtelcoa__Solution_Status__c IN ('Active', 'Completed');

-- 2. Monthly Recurring Revenue
SELECT SUM(cscfga__Total_Recurring_Charge__c) FROM csord__Solution__c 
WHERE csordtelcoa__Solution_Status__c = 'Active';

-- 3. Average Order Value
SELECT AVG(TotalAmount) FROM csord__Order__c 
WHERE csordtelcoa__Order_Status__c = 'COMPLETED'
AND CreatedDate >= LAST_N_DAYS:90;

-- 4. Revenue by Product Type
SELECT 
  cssdm__Solution_Definition__r.Name AS ProductType,
  COUNT(Id) AS Count,
  SUM(Total_Contract_Value__c) AS TotalValue,
  AVG(Total_Contract_Value__c) AS AvgValue
FROM csord__Solution__c
WHERE csordtelcoa__Solution_Status__c = 'Active'
GROUP BY cssdm__Solution_Definition__r.Name
ORDER BY SUM(Total_Contract_Value__c) DESC;
```

### B. Operational Metrics

```sql
-- 1. Order Cycle Time by Stage
SELECT 
  csordtelcoa__Order_Status__c AS Stage,
  COUNT(Id) AS OrderCount,
  AVG(DAYS_BETWEEN(CreatedDate, LastModifiedDate)) AS AvgDaysInStage
FROM csord__Order__c
WHERE CreatedDate >= LAST_N_DAYS:90
GROUP BY csordtelcoa__Order_Status__c;

-- 2. Process Compliance (Orchestration)
SELECT 
  (SELECT COUNT(Id) FROM CSPOFA__Orchestration_Step__c 
   WHERE CSPOFA__Process_Status__c = 'Complete' 
   AND CreatedDate >= LAST_N_DAYS:30) * 100.0 / 
  (SELECT COUNT(Id) FROM CSPOFA__Orchestration_Step__c 
   WHERE CreatedDate >= LAST_N_DAYS:30) AS ComplianceRate;

-- 3. Error Rate by Step
SELECT 
  CSPOFA__Step_Name__c,
  COUNT(Id) AS TotalAttempts,
  SUM(CASE WHEN CSPOFA__Process_Status__c = 'Error' THEN 1 ELSE 0 END) AS Errors,
  (SUM(CASE WHEN CSPOFA__Process_Status__c = 'Error' THEN 1 ELSE 0 END) * 100.0 / COUNT(Id)) AS ErrorRate
FROM CSPOFA__Orchestration_Step__c
WHERE CreatedDate >= LAST_N_DAYS:30
GROUP BY CSPOFA__Step_Name__c
HAVING COUNT(Id) > 100
ORDER BY ErrorRate DESC
LIMIT 20;
```

### C. Issue Impact Metrics

```sql
-- 1. Issues by Category with Financial Impact
SELECT 
  'Failed Migrations' AS Category,
  COUNT(Id) AS IssueCount,
  SUM(Total_Contract_Value__c) AS RevenueImpact,
  'MACD Blocked' AS CustomerImpact
FROM csord__Solution__c
WHERE csord__External_Identifier__c = 'Not Migrated Successfully'

UNION ALL

SELECT 
  'Stuck Baskets' AS Category,
  COUNT(Id) AS IssueCount,
  SUM(cscfga__Total_One_Off_Charge__c + cscfga__Total_Recurring_Charge__c * 12) AS RevenueImpact,
  'Order Delayed' AS CustomerImpact
FROM cscfga__Product_Basket__c
WHERE cscfga__Basket_Status__c = 'Order Generation'
AND CreatedDate >= LAST_N_DAYS:90;

-- 2. Time to Resolution by Issue Type
SELECT 
  RecordType.Name AS IssueType,
  AVG(DAYS_BETWEEN(CreatedDate, ClosedDate)) AS AvgResolutionDays,
  MIN(DAYS_BETWEEN(CreatedDate, ClosedDate)) AS BestCase,
  MAX(DAYS_BETWEEN(CreatedDate, ClosedDate)) AS WorstCase,
  COUNT(Id) AS TotalCases
FROM Case
WHERE Status = 'Closed'
AND CreatedDate >= LAST_N_DAYS:90
GROUP BY RecordType.Name
ORDER BY AVG(DAYS_BETWEEN(CreatedDate, ClosedDate)) DESC;
```

